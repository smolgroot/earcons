{
  "name": "earcons",
  "version": "0.1.0",
  "description": "Tiny vanilla TypeScript library for playing UI notification sounds via the Web Audio API — no audio files, no dependencies.",
  "keywords": [
    "web-audio-api",
    "notification",
    "sound",
    "ui",
    "earcon",
    "sfx",
    "typescript",
    "browser",
    "audio",
    "beep"
  ],
  "author": {
    "name": "smolgroot",
    "url": "https://github.com/smolgroot"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smolgroot/earcons.git"
  },
  "homepage": "https://github.com/smolgroot/earcons#readme",
  "bugs": {
    "url": "https://github.com/smolgroot/earcons/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "browser": "./dist/earcon.min.global.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
